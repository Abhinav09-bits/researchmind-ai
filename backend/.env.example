# Copy this to .env and fill in your values

# Gemini API — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Qdrant Cloud — https://cloud.qdrant.io
QDRANT_HOST=https://your-cluster.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key_here

# GitHub — optional, needed for private repos or high-volume indexing
GITHUB_TOKEN=github_pat_...

# CORS — comma-separated, set to your Vercel URL in production
ALLOWED_ORIGINS=*

# App
APP_ENV=development
LOG_LEVEL=INFO

# RAG tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
SIMILARITY_SCORE_THRESHOLD=0.6
